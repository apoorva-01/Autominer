{
  "name": "slack-automation-discovery",
  "version": "1.0.0",
  "description": "Slack-powered workflow automation discovery system",
  "main": "index.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "start": "cd backend && npm start"
  },
  "keywords": [
    "slack",
    "automation",
    "workflow",
    "discovery",
    "pipedream"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "concurrently": "^8.2.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "@xyflow/react": "^12.8.2",
    "axios": "^1.10.0",
    "dagre": "^0.8.5",
    "dotenv-cli": "^8.0.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-error-boundary": "^6.0.0",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.2",
    "react-window": "^1.8.11"
  }
}
