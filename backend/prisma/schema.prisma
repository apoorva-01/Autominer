generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  name              String?
  password          String
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  role              String                  @default("user")
  reports           AutomationReport[]
  channelSelections SlackChannelSelection[]
  slackConnections  SlackConnection[]

  @@map("users")
}

model SlackConnection {
  id                String                  @id @default(cuid())
  userId            String
  slackUserId       String
  slackTeamId       String
  slackTeamName     String
  pipedreamConnId   String?
  accessToken       String?
  scopes            String[]
  isActive          Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  userToken         String?
  channelSelections SlackChannelSelection[]
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations     SlackConversation[]
  scrapingJobs      SlackScrapingJob[]

  @@unique([userId, slackTeamId])
  @@index([slackTeamId])
  @@index([userId])
  @@index([isActive])
  @@map("slack_connections")
}

model SlackScrapingJob {
  id                String          @id @default(cuid())
  slackConnectionId String
  channelId         String
  channelName       String?
  channelType       String
  status            String          @default("pending")
  progress          Int             @default(0)
  messagesScraped   Int             @default(0)
  totalMessages     Int?
  lastMessageTs     String?
  errorMessage      String?
  notes             String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  jobType           String?
  params            String?         // Added field for job parameters (JSON string)
  slackConnection   SlackConnection @relation(fields: [slackConnectionId], references: [id], onDelete: Cascade)

  @@unique([slackConnectionId, channelId])
  @@map("slack_scraping_jobs")
}

model SlackConversation {
  id                String           @id @default(cuid())
  slackConnectionId String
  messageTs         String
  channelId         String
  channelName       String?
  userId            String
  userName          String?
  messageText       String
  messageType       String
  threadTs          String?
  participants      String[]
  tags              String[]
  createdAt         DateTime         @default(now())
  slackSentAt       DateTime
  automationTasks   AutomationTask[]
  slackConnection   SlackConnection  @relation(fields: [slackConnectionId], references: [id], onDelete: Cascade)

  @@unique([slackConnectionId, messageTs])
  @@index([slackConnectionId])
  @@index([messageType])
  @@index([userId])
  @@index([channelId])
  @@index([slackSentAt])
  @@index([slackConnectionId, messageType])
  @@index([slackConnectionId, channelId])
  @@index([slackConnectionId, userId])
  @@index([slackConnectionId, messageType, userId])
  @@map("slack_conversations")
}

model AutomationTask {
  id                        String                 @id @default(cuid())
  slackConversationId       String
  title                     String                 // Short, clear name for the task
  taskDescription           String                 // Plain-English description of the repetitive action
  currentManualSteps        String                 // Brief outline of how humans do it today
  frequencyScore            Int                    // Integer from 1–5
  automationEaseScore       Int                    // Integer from 1–5
  priorityScore             Int                    // Frequency × Ease
  suggestedAutomationApproach String               // Concrete idea for automation
  estimatedTimeSaved        String                 // Rough minutes saved each time the automation runs
  rationale                 String                 // 2–3 sentences explaining the scores and approach
  frequency                 String                 // (legacy, can be kept for compatibility)
  difficulty                String                 // (legacy, can be kept for compatibility)
  estimatedRoi              String                 // (legacy, can be kept for compatibility)
  suggestedTools            String[]
  confidence                Float
  status                    String                 @default("pending")
  createdAt                 DateTime               @default(now())
  analysisId                String?                // ID of the analysis run that created this task
  reports                   AutomationReportTask[]
  slackConversation         SlackConversation      @relation(fields: [slackConversationId], references: [id], onDelete: Cascade)

  @@map("automation_tasks")
}

model AutomationReport {
  id        String                 @id @default(cuid())
  userId    String
  title     String
  period    String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime               @default(now())
  tasks     AutomationReportTask[]
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("automation_reports")
}

model AutomationReportTask {
  id               String           @id @default(cuid())
  reportId         String
  automationTaskId String
  rank             Int
  automationTask   AutomationTask   @relation(fields: [automationTaskId], references: [id], onDelete: Cascade)
  report           AutomationReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, automationTaskId])
  @@map("automation_report_tasks")
}

model SlackChannelSelection {
  id                 String          @id @default(cuid())
  userId             String
  slackConnectionId  String
  channelId          String
  channelName        String?
  channelType        String
  isActive           Boolean         @default(true)
  lastFetchedAt      DateTime?
  totalMessages      Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  dailyExportEnabled Boolean         @default(false)
  googleDocId        String?
  googleDocUrl       String?
  slackConnection    SlackConnection @relation(fields: [slackConnectionId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleDocs         SlackChannelGoogleDoc[]

  @@unique([slackConnectionId, channelId])
  @@map("slack_channel_selections")
}

model SlackChannelGoogleDoc {
  id                    String                @id @default(cuid())
  slackChannelSelectionId String
  docId                 String
  docUrl                String
  createdAt             DateTime              @default(now())
  exportType            String                // 'history' or 'daily'
  slackChannelSelection SlackChannelSelection @relation(fields: [slackChannelSelectionId], references: [id], onDelete: Cascade)

  @@map("slack_channel_google_docs")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  departmentRoles DepartmentRole[]
}

model DepartmentAssignment {
  id           String   @id @default(cuid())
  userId       String
  department   String
  connectionId String
  managerId    String? // new: manager (userId) for org chart
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([department])
  @@index([connectionId])
  @@index([userId])
  @@index([managerId])
  @@index([department, connectionId])
}

model DepartmentRole {
  id           String   @id @default(cuid())
  userId       String
  department   String
  roleId       String
  slackTeamId  String   // changed from connectionId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  role         Role     @relation(fields: [roleId], references: [id])
}

model Department {
  id           String   @id @default(cuid())
  name         String
  description  String?
  slackTeamId  String   // <-- changed from connectionId
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
